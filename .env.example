# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Dynatrace OpenTelemetry Configuration
# Your Dynatrace environment URL (no trailing slash)
DT_API_URL=https://<your-env>.live.dynatrace.com/api/v2/otlp
# Dynatrace API token with openTelemetryTrace.ingest scope
DT_API_TOKEN=your_dynatrace_api_token_here
